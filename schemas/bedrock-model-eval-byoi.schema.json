{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bedrock Model Evaluation BYOI Row",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt", "modelResponses"],
  "properties": {
    "prompt": {"type": "string", "minLength": 1},
    "referenceResponse": {"type": "string"},
    "category": {"type": "string"},
    "modelResponses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["response", "modelIdentifier"],
        "properties": {
          "response": {"type": "string", "minLength": 1},
          "modelIdentifier": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
