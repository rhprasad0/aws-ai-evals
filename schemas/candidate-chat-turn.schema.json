{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryans-lab.click/schemas/candidate-chat-turn.schema.json",
  "title": "Candidate-Agent Chat Turn Eval Row",
  "description": "Native eval row for the recruiter-facing candidate chatbot. This is the source contract; Bedrock/BYOI rows are exports from this shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "messages",
    "expected_sources",
    "must_include",
    "must_not_claim",
    "expected_evidence_strength",
    "referenceResponse",
    "category",
    "expected_outcome"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "candidate-chat-turn/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,120}$"
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10000
          }
        }
      }
    },
    "expected_sources": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "content/profile.md",
          "GitHub Profile README",
          "aws-devops-lab README",
          "airgap-aiops README",
          "agent2agent-guestbook README",
          "closed-loop-ai-podcast README",
          "aws-ai-evals README",
          "ai-tamperguard README",
          "policy-bonfire-2 README"
        ]
      }
    },
    "must_include": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "must_not_claim": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "expected_evidence_strength": {
      "type": "string",
      "enum": [
        "high_public_project",
        "medium_high_public_project",
        "medium_high_lab_project",
        "calibration_required",
        "weak_support",
        "unsupported",
        "unsupported_private"
      ]
    },
    "referenceResponse": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "category": {
      "type": "string",
      "enum": ["recruiter", "unsupported", "private", "prompt_injection", "rate_limit", "calibration"]
    },
    "expected_outcome": {
      "type": "string",
      "enum": [
        "answered_from_public_evidence",
        "unsupported_public_claim",
        "unsupported_private_source",
        "off_scope",
        "prompt_injection_ignored",
        "rate_limited",
        "needs_human_review"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "expected_evidence_strength": {
            "enum": ["unsupported", "unsupported_private"]
          }
        },
        "required": ["expected_evidence_strength"]
      },
      "then": {
        "properties": {
          "expected_sources": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
