{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryans-lab.click/schemas/human-label.schema.json",
  "title": "Candidate Chatbot Human Label Row",
  "description": "Human-curated Week 5 calibration label for one example and one rubric. These labels are stored separately from generated judge outputs and joined by example_id and rubric_id.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "example_id",
    "source_dataset",
    "rubric_id",
    "rubric_version",
    "expected_score",
    "expected_score_label",
    "human_rationale",
    "labeler",
    "label_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "candidate-human-label/v1"
    },
    "example_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,120}$"
    },
    "source_dataset": {
      "type": "string",
      "enum": [
        "datasets/synthetic/recruiter-evidence-qa.jsonl",
        "datasets/synthetic/candidate-chat-turns.jsonl"
      ]
    },
    "rubric_id": {
      "type": "string",
      "enum": [
        "correctness",
        "completeness",
        "citation_support",
        "refusal_appropriateness",
        "evidence_strength_calibration"
      ]
    },
    "rubric_version": {
      "type": "string",
      "enum": [
        "candidate-correctness/v1",
        "candidate-completeness/v1",
        "candidate-citation-support/v1",
        "candidate-refusal-appropriateness/v1",
        "candidate-evidence-strength/v1"
      ]
    },
    "expected_score": {
      "type": "integer",
      "enum": [
        0,
        1,
        2
      ]
    },
    "expected_score_label": {
      "type": "string",
      "enum": [
        "fail",
        "partial",
        "pass"
      ]
    },
    "expected_failure_labels": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "unsupported_claim",
          "citation_missing",
          "citation_invalid",
          "citation_does_not_support_claim",
          "evidence_strength_overstated",
          "evidence_strength_understated",
          "private_source_claim",
          "over_refusal",
          "under_refusal",
          "material_omission",
          "schema_or_parse_issue",
          "high_variance_candidate"
        ]
      }
    },
    "expected_evidence_strength": {
      "type": "string",
      "enum": [
        "high_public_project",
        "medium_high_public_project",
        "medium_high_lab_project",
        "calibration_required",
        "weak_support",
        "unsupported",
        "unsupported_private"
      ]
    },
    "expected_outcome": {
      "type": "string",
      "enum": [
        "answered_from_public_evidence",
        "unsupported_public_claim",
        "unsupported_private_source",
        "off_scope",
        "prompt_injection_ignored",
        "rate_limited",
        "needs_human_review"
      ]
    },
    "human_rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "labeler": {
      "type": "string",
      "enum": [
        "human-curated-contract"
      ]
    },
    "label_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "expected_score": {
            "const": 0
          }
        },
        "required": [
          "expected_score"
        ]
      },
      "then": {
        "properties": {
          "expected_score_label": {
            "const": "fail"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "expected_score": {
            "const": 1
          }
        },
        "required": [
          "expected_score"
        ]
      },
      "then": {
        "properties": {
          "expected_score_label": {
            "const": "partial"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "expected_score": {
            "const": 2
          }
        },
        "required": [
          "expected_score"
        ]
      },
      "then": {
        "properties": {
          "expected_score_label": {
            "const": "pass"
          }
        }
      }
    }
  ]
}
