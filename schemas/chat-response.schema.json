{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryans-lab.click/schemas/chat-response.schema.json",
  "title": "Candidate Chatbot Response",
  "description": "Runtime response contract for the candidate-evidence chatbot. schema_version is optional for backwards compatibility with the deployed API.",
  "type": "object",
  "additionalProperties": false,
  "required": ["answer", "citations", "evidenceStrength", "unsupportedClaims"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "candidate-chat-response/v1"
    },
    "answer": {"type": "string", "minLength": 1, "maxLength": 20000},
    "citations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "content/profile.md",
          "GitHub Profile README",
          "aws-devops-lab README",
          "airgap-aiops README",
          "agent2agent-guestbook README",
          "closed-loop-ai-podcast README",
          "aws-ai-evals README",
          "ai-tamperguard README",
          "policy-bonfire-2 README"
        ]
      }
    },
    "evidenceStrength": {
      "type": "string",
      "enum": [
        "high_public_project",
        "medium_high_public_project",
        "medium_high_lab_project",
        "calibration_required",
        "weak_support",
        "unsupported",
        "unsupported_private"
      ]
    },
    "unsupportedClaims": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "evidenceStrength": {
            "enum": ["unsupported", "unsupported_private"]
          }
        },
        "required": ["evidenceStrength"]
      },
      "then": {
        "properties": {
          "citations": {"maxItems": 0},
          "unsupportedClaims": {"minItems": 1}
        }
      }
    }
  ]
}
