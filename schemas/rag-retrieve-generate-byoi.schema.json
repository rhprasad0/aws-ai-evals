{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryans-lab.click/schemas/rag-retrieve-generate-byoi.schema.json",
  "title": "Bedrock Retrieve-and-Generate RAG Evaluation BYOI Row",
  "description": "One JSONL row for Amazon Bedrock RAG evaluation where an external grounded-answer system provides both generated output and retrieved passages.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "conversationTurns"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bedrock-rag-retrieve-generate-byoi/v1"
    },
    "conversationTurns": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt", "referenceResponses", "output"],
        "properties": {
          "prompt": {"$ref": "#/$defs/textContentBlock"},
          "referenceResponses": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/textContentBlock"}
          },
          "referenceContexts": {
            "type": "array",
            "items": {"$ref": "#/$defs/textContentBlock"}
          },
          "output": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "knowledgeBaseIdentifier", "retrievedPassages"],
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 20000},
              "knowledgeBaseIdentifier": {"type": "string", "minLength": 1, "maxLength": 200},
              "modelIdentifier": {"type": "string", "minLength": 1, "maxLength": 200},
              "retrievedPassages": {
                "type": "object",
                "additionalProperties": false,
                "required": ["retrievalResults"],
                "properties": {
                  "retrievalResults": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"$ref": "#/$defs/retrievalResult"}
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "textContentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 20000}
            }
          }
        }
      }
    },
    "retrievalResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 200},
        "content": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {"type": "string", "minLength": 1, "maxLength": 20000}
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {"type": ["string", "number", "boolean"]}
        }
      }
    }
  }
}
