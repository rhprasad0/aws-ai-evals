{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryans-lab.click/schemas/judge-output.schema.json",
  "title": "Candidate Chatbot Judge Output Row",
  "description": "One machine-parseable LLM-as-judge output for a single rubric, example, run, and repeated-run index. Human labels live separately and are joined by example_id/rubric_id during calibration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "example_id",
    "run_id",
    "rubric_id",
    "rubric_version",
    "judge_model_id",
    "repetition_index",
    "score",
    "score_label",
    "rationale",
    "requires_human_review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "candidate-judge-output/v1"
    },
    "example_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.:-]{2,160}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.:-]{2,160}$"
    },
    "rubric_id": {
      "type": "string",
      "enum": [
        "correctness",
        "completeness",
        "citation_support",
        "refusal_appropriateness",
        "evidence_strength_calibration"
      ]
    },
    "rubric_version": {
      "type": "string",
      "enum": [
        "candidate-correctness/v1",
        "candidate-completeness/v1",
        "candidate-citation-support/v1",
        "candidate-refusal-appropriateness/v1",
        "candidate-evidence-strength/v1"
      ]
    },
    "judge_model_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "repetition_index": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "bedrock_job_arn": {
      "type": "string",
      "pattern": "^arn:aws[a-zA-Z-]*:bedrock:[a-z0-9-]+:[0-9]{12}:evaluation-job/[A-Za-z0-9_.:-]+$"
    },
    "bedrock_output_record_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "score": {
      "type": "integer",
      "enum": [
        0,
        1,
        2
      ]
    },
    "score_label": {
      "type": "string",
      "enum": [
        "fail",
        "partial",
        "pass"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "failure_labels": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "unsupported_claim",
          "citation_missing",
          "citation_invalid",
          "citation_does_not_support_claim",
          "evidence_strength_overstated",
          "evidence_strength_understated",
          "private_source_claim",
          "over_refusal",
          "under_refusal",
          "material_omission",
          "schema_or_parse_issue",
          "high_variance_candidate"
        ]
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "requires_human_review": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "score": {
            "const": 0
          }
        },
        "required": [
          "score"
        ]
      },
      "then": {
        "properties": {
          "score_label": {
            "const": "fail"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "score": {
            "const": 1
          }
        },
        "required": [
          "score"
        ]
      },
      "then": {
        "properties": {
          "score_label": {
            "const": "partial"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "score": {
            "const": 2
          }
        },
        "required": [
          "score"
        ]
      },
      "then": {
        "properties": {
          "score_label": {
            "const": "pass"
          }
        }
      }
    }
  ]
}
